{
  "$schema": "https://raw.githubusercontent.com/anthropics/claude-code/main/.mcp.schema.json",
  "mcpServers": {
    "context7": {
      "$comment": "Up-to-date documentation and code examples via Context7",
      "command": "/bin/bash",
      "args": ["-l", "-c", "exec npx -y @upstash/context7-mcp@latest"]
    },
    "sequential-thinking": {
      "$comment": "Step-by-step reasoning for complex problems",
      "command": "/bin/bash",
      "args": ["-l", "-c", "exec npx -y @modelcontextprotocol/server-sequential-thinking"]
    },
    "youtube-transcript": {
      "$comment": "YouTube 자막 추출 - 로그인/API 키 불필요",
      "command": "/bin/bash",
      "args": ["-l", "-c", "exec npx -y @kimtaeyoon83/mcp-server-youtube-transcript"]
    },
    "gemini-cli": {
      "$comment": "Gemini CLI - Google 계정 로그인 기반. Summary 생성, 프롬프트 작성 담당",
      "command": "/bin/bash",
      "args": ["-l", "-c", "exec npx -y gemini-mcp-tool"]
    },
    "notebooklm-mcp": {
      "$comment": "NotebookLM MCP - 노트북 생성, 오디오/비디오 생성 자동화",
      "command": "/bin/bash",
      "args": ["-l", "-c", "DISPLAY=:99 exec npx -y notebooklm-mcp"],
      "env": {
        "DISPLAY": ":99"
      }
    }
  },
  "staggeredStartup": {
    "enabled": true,
    "delayMs": 500,
    "connectionTimeout": 15000
  }
}
